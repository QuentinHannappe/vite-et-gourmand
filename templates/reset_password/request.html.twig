{% extends 'base.html.twig' %}

{% block title %}reinitialisez votre mot de passe{% endblock %}

{% block body %}
<div class="row justify-content-center">
       <div class="col-4 mt-4 mb-4">
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    <h1>reinitialisez votre mot de passe</h1>

    {{ form_start(requestForm) }}
        {{ form_row(requestForm.email) }}
        <div>
            <small>
                Entrez votre adresse email et nous vous enveront un lien pour reinitialisez votre mot de passe.
            </small>
        </div>

        <button class="btn-getstarted mt-4 mb-4">Demander le lien</button>
    {{ form_end(requestForm) }}
{% endblock %}
