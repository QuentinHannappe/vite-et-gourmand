{% extends 'base.html.twig' %}

{% block title %}Nos Menus - Vite & Gourmand{% endblock %}

{% block body %}
<section class="section">
    <div class="container section-title">
        <p><span>Découvrez</span> <span class="description-title">Nos Menus</span></p>
    </div>


{{ form_start(form) }}
<div class="container text-left">
 <div class="row">
    <div class="col-4">
    {{ form_row(form.theme) }}
    </div>

    <div class="col-4">
    {{ form_row(form.regime) }}
    </div>
    
    <div class="col-4">
    {{ form_row(form.min) }}
    {{ form_row(form.max) }}
    {{ form_row(form.minPersonnes) }}
    </div>
    </div>
{{ form_end(form) }}
</div>

</div>

    <div class="container">
        <div class="row gy-4" id="menus-container">
            {% for menu in menus %}
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 p-3">

<div id="carousel-{{ menu.id }}" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        {% for plat in menu.plats %}
        <div class="carousel-item {% if loop.first %}active{% endif %}">
            <img src="{{ asset(plat.photo) }}" class="d-block w-100" alt="{{ plat.titre }}" style="height: 300px; object-fit: contain;">
        </div>
        {% endfor %}
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carousel-{{ menu.id }}" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carousel-{{ menu.id }}" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

    <div class="card-body">
       <h4 class="card-title">{{ menu.titre }}</h4>
       <p class="card-text">{{ menu.description }}</p>
       <p><strong>Prix :</strong> {{ menu.prixParPersonne }}€ / personne</p>
       <p><strong>Minimum :</strong> {{ menu.personnesMin }} personnes</p>
       <a href="#" class="btn-getstarted">Voir le détail</a>
    </div>
     </div>
      </div>
            {% endfor %}
            
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/filtres.js') }}"></script>
{% endblock %}