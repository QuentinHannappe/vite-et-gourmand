{% extends 'base.html.twig' %}

{% block title %}Employé{% endblock %}

{% block body %}
<div class="row justify-content-center">
<div class="col-7 mt-4 mb-4">
<h3 class="mt-4">Commandes</h3>

<form method="GET">
    <select name="statut">
        <option value="">Tous les statuts</option>
        <option value="en attente">En attente</option>
        <option value="accepté">Accepté</option>
        <option value="en préparation">En préparation</option>
    </select>
    <input type="text" name="client" placeholder="Nom du client">
    <button type="submit" class="btn-getstarted mb-2">Filtrer</button>
</form>

{% for commande in commandes %}
<div class="card mb-3">
<div class="card-body">
       <p><strong>Num commande : </strong>{{ commande.numeroCommande }}</p>
       <p><strong>Statut : </strong>{{ commande.statut }}</p>
       <p><strong>Client :</strong> {{ commande.users.nom }} {{ commande.users.prenom }}</p>
       <p><strong>Date presta : </strong>{{ commande.datePresta | date('d/m/Y') }}</p>
       <p><strong>Heure livraison : </strong>{{ commande.heureLivraison }}</p>
       <p><strong>Menu : </strong>{{ commande.menu.titre }}</p>
       <p><strong>Nbr de personnes : </strong>{{ commande.nombrePersonnes }}</p>
       <p><strong>Prix total : </strong>{{ commande.prixMenu}}<strong>€</strong></p>
       <p><strong>Prix livraison : </strong>{{ commande.prixLivraison }}</p>
       <form method="POST" action="{{ path('app_statut', {'id': commande.id}) }}">
    <select name="statut">
        <option value="accepté">Accepté</option>
        <option value="en préparation">En préparation</option>
        <option value="en cours de livraison">En cours de livraison</option>
        <option value="livré">Livré</option>
        <option value="terminée">Terminée</option>
    </select>
    <p><button type="submit" class="btn-getstarted , mt-2">Valider le statut</button></p>
</form>
      </div>
    </div>
     {% endfor %}
</div>
{% endblock %}
