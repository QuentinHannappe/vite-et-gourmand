{% extends 'base.html.twig' %}

{% block title %}Employé{% endblock %}

{% block body %}
<div class="row justify-content-center">
<div class="col-7 mt-4 mb-4">
<h3 class="mt-4">Commandes</h3>

<form method="GET">
    <select name="statut">
        <option value="">Tous les statuts</option>
        <option value="en attente">En attente</option>
        <option value="accepté">Accepté</option>
        <option value="en préparation">En préparation</option>
    </select>
    <input type="text" name="client" placeholder="Nom du client">
    <button type="submit" class="btn-getstarted mb-2">Filtrer</button>
</form>

{% for commande in commandes %}
<div class="card mb-3">
<div class="card-body">
       <p><strong>Num commande : </strong>{{ commande.numeroCommande }}</p>
       <p><strong>Statut : </strong>{{ commande.statut }}</p>
       <p><strong>Client :</strong> {{ commande.users.nom }} {{ commande.users.prenom }}</p>
       <p><strong>Date presta : </strong>{{ commande.datePresta | date('d/m/Y') }}</p>
       <p><strong>Heure livraison : </strong>{{ commande.heureLivraison }}</p>
       <p><strong>Menu : </strong>{{ commande.menu.titre }}</p>
       <p><strong>Nbr de personnes : </strong>{{ commande.nombrePersonnes }}</p>
       <p><strong>Prix total : </strong>{{ commande.prixMenu}}<strong>€</strong></p>
       <p><strong>Prix livraison : </strong>{{ commande.prixLivraison }}</p>


    <form method="POST" action="{{ path('app_statut', {'id': commande.id}) }}">
    <select name="statut">
        <option value="accepté">Accepté</option>
        <option value="en préparation">En préparation</option>
        <option value="en cours de livraison">En cours de livraison</option>
        <option value="livré">Livré</option>
        <option value="terminée">Terminée</option>
    </select>
    <p><button type="submit" class="btn-getstarted , mt-2">Valider le statut</button></p>
    </form>
      </div>
    </div>
     {% endfor %}

<h3 class="mt-4">Avis en attente</h3>

{% for avis in avis %}
<div class="card mb-3">
    <div class="card-body">
        <p><strong>Note :</strong> {{ avis.note }}/5</p>
        <p><strong>Commentaire :</strong> {{ avis.commentaire }}</p>
        <p><strong>Client :</strong> {{ avis.commande.users.nom }} {{ avis.commande.users.prenom }}</p>
        
        <form method="POST" action="{{ path('app_valider_avis', {'id': avis.id}) }}">
            <select name="statut">
                <option value="validé">Valider</option>
                <option value="refusé">Refuser</option>
            </select>
            <button type="submit" class="btn-getstarted mt-2">Confirmer</button>
        </form>
    </div>
</div>
{% endfor %}

<h3 class="mt-4">Employés</h3>

<p><a href="{{ path('app_creer_employe') }}" class="btn-getstarted mb-5">Créer un employé</a></p>

{% for employe in employes %}
    {% if 'ROLE_EMPLOYE' in employe.roles %}
        <div class="card mb-3">
            <div class="card-body">
                <p><strong>Email :</strong> {{ employe.email }}</p>
                <p><strong>Actif :</strong> {{ employe.isActive ? 'Oui' : 'Non' }}</p>
                <a href="{{ path('app_desactiver_employe', {'id': employe.id}) }}" class="btn-getstarted">Désactiver</a>
            </div>
        </div>
    {% endif %}
{% endfor %}

<a href="{{ path('gestionmenu') }}" class="btn-getstarted">Gérer les menus</a>
<a href="{{ path('gestionmenu_plat_index') }}" class="btn-getstarted">Gérer les plats</a>

</div>
{% endblock %}